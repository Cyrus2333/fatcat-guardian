{
  "name": "fatcat-guardian",
  "productName": "FatCat Guardian",
  "description": "A tray-first desktop break reminder that covers your screen with a fat cat.",
  "author": "Huang Jingye",
  "license": "GPL-3.0-only",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node ./node_modules/electron/cli.js ./electron/main.cjs",
    "start": "node ./node_modules/electron/cli.js ./electron/main.cjs",
    "check": "node --check electron/main.cjs && node --check electron/preload.cjs && node --check electron/overlay.js && node --check electron/settings.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.fatcat.guardian",
    "productName": "FatCat Guardian",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/assets/tray-icon-win.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.6.3"
  }
}
